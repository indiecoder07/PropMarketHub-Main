# Clerk Auth (https://clerk.com → create app → API keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/admin/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/admin/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/admin

# Neon Database (https://neon.tech → create project → connection string)
DATABASE_URL=postgresql://user:password@ep-xxxxx.region.neon.tech/neondb?sslmode=require

# Suburb Scorecard Vercel URL (for proxy)
SUBURB_SCORECARD_URL=https://your-suburb-scorecard.vercel.app
