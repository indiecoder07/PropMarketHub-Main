# ============================================================
# PROPMARKETHUB HUB — Environment Variables
# ============================================================
# LOCAL DEVELOPMENT:
#   cp .env.local.example .env.local
#   Fill in your values — never commit .env.local to git.
#
# VERCEL (PRODUCTION):
#   Vercel Dashboard → Your Project → Settings → Environment Variables
#   Add each variable below with its production value.
#   Mark variables as "Production", "Preview", and/or "Development"
#   as appropriate.
# ============================================================


# ============================================================
# 🔴 REQUIRED — App will not work without these
# ============================================================

# ---- Clerk Authentication ----
# Dashboard: https://dashboard.clerk.com → Your App → API Keys
# Use "Publishable Key" (pk_example_...) and "Secret Key" (sk_example_...)
# For local dev, use pk_example_... / sk_example_... keys instead.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_example_x
CLERK_SECRET_KEY=sk_example_x

# Clerk redirect paths (leave these as-is)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/admin/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/admin/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/admin
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/admin

# ---- Neon Postgres Database ----
# Dashboard: https://console.neon.tech → Your Project → Connection Details
# Copy the "Connection string" (includes ?sslmode=require at the end)
DATABASE_URL=postgresql://user:password@ep-xxxxxx-xxxxxx.ap-southeast-2.aws.neon.tech/neondb?sslmode=require

# ---- Suburb Scorecard Proxy ----
# The Vercel deployment URL of the separate Suburb Scorecard Vite app.
# Vercel Dashboard → Suburb Scorecard project → Deployments tab → copy the .vercel.app URL
# Hub rewrites /suburb-scorecard/* to this URL (configured in next.config.mjs).
# ⚠️  No trailing slash. Include https://
SUBURB_SCORECARD_URL=https://your-suburb-scorecard.vercel.app

# ---- Site Public URL ----
# Must match your production domain exactly. No trailing slash.
# Used for canonical URLs and any server-side absolute link generation.
NEXT_PUBLIC_SITE_URL=https://propmarkethub.com.au


# ============================================================
# 🟡 RECOMMENDED — Important for production, optional for dev
# ============================================================

# ---- Google Analytics 4 ----
# GA4 Console → Admin (⚙) → Data Streams → Your Web Stream → Measurement ID
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX


# ============================================================
# 🟢 OPTIONAL — Enable only if you use these features
# ============================================================

# ---- Resend — Transactional Email ----
# Used for contact forms, admin notifications, etc.
# Dashboard: https://resend.com/api-keys → Create API Key
# ⚠️  Verify your sending domain in Resend before going live.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@propmarkethub.com.au

# ---- EmailOctopus — Newsletter / Mailing List ----
# Used for lead capture and newsletter sign-ups.
# ⚠️  These are SERVER-SIDE ONLY — do not prefix with NEXT_PUBLIC_.
# API Key:  https://emailoctopus.com/account/api
# List ID:  EmailOctopus → Audience → Your List → Settings
EMAILOCTOPUS_API_KEY=
EMAILOCTOPUS_LIST_ID=
EMAILOCTOPUS_FROM_EMAIL=hello@propmarkethub.com.au
EMAILOCTOPUS_FROM_NAME=PropMarketHub

# ---- Cron Job Secret ----
# Protects API routes that are triggered by Vercel Cron Jobs.
# Generate a strong random value with:  openssl rand -hex 32
# Set the SAME value in Vercel → Settings → Environment Variables.
CRON_SECRET=


# ============================================================
# 📋 VERCEL DEPLOYMENT CHECKLIST
# ============================================================
# Before clicking "Deploy" on Vercel, confirm:
#
# ✅ NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY  — Clerk live key (pk_example_...)
# ✅ CLERK_SECRET_KEY                   — Clerk live key (sk_example_...)
# ✅ DATABASE_URL                        — Neon production connection string
# ✅ SUBURB_SCORECARD_URL                — Deployed Vite app URL (no trailing /)
# ✅ NEXT_PUBLIC_SITE_URL                — https://propmarkethub.com.au
# ✅ NEXT_PUBLIC_GA4_ID                  — G-XXXXXXXXXX (if using GA4)
#
# Optional (fill if feature is live):
# ⬜ RESEND_API_KEY                      — Transactional email
# ⬜ EMAIL_FROM                          — Verified sender address
# ⬜ EMAILOCTOPUS_API_KEY                — Newsletter integration
# ⬜ EMAILOCTOPUS_LIST_ID                — Your mailing list ID
# ⬜ CRON_SECRET                         — If using Vercel Cron Jobs
# ============================================================
